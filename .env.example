# Binance Spot DEMO API credentials
# binance.com → Demo Trading → API Management (Spot demo keys)
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_api_secret_here

# Telegram alerts (optional — leave empty to disable)
# 1) Telegram'da @BotFather → /newbot → token al
# 2) Bota bir mesaj at, sonra chat id: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Order size in USDT (quote spent on each spot market buy)
ORDER_USDT=100

# Max concurrent REST fetches during warmup
MAX_CONCURRENCY=20

# 1m pump hunter filters
MIN_CANDLE_QUOTE_VOL=10000
VOL_LOOKBACK=20
VOL_MULT=3.0
MIN_CANDLE_PCT=4.0

# FBB band refresh interval (seconds) for all coins; volume is on-demand only
FBB_REFRESH_SEC=90

# Exit: entry 1m candle low | EMA9 5m until 1m CLOSE +TRAIL_ACTIVATE_PCT% | then TRAIL_PCT% trail (floor=entry)
TRAIL_ACTIVATE_PCT=3.0
TRAIL_PCT=5.0

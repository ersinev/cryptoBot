# Binance Spot DEMO API credentials
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_api_secret_here

# Telegram alerts (optional — leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Order size in USDT (quote spent on each spot market buy)
ORDER_USDT=100

# Max concurrent REST fetches during warmup
MAX_CONCURRENCY=20

# 1m entry filters (prev closed 1m quote vol only — no rel)
MIN_CANDLE_QUOTE_VOL=10000
VOL_LOOKBACK=20
VOL_MULT=3.0
MIN_CANDLE_PCT=2.0

# FBB band refresh interval (seconds)
FBB_REFRESH_SEC=90

# Exit: hard -1.5% | 70%@+3 | BE +0.3% after partial | trail +5% / -2%
# No entry-candle-low, no EMA (USE_EMA_EXIT=0)
PARTIAL_LADDER=3:0.70
HARD_STOP_PCT=1.5
USE_ENTRY_CANDLE_STOP=0
USE_BREAKEVEN=1
BREAKEVEN_PCT=0.3
USE_EMA_EXIT=0
EMA_PROGRESSIVE=0
EMA_EXIT_TF=5m
EMA_PROG_MODE=1m2m
USE_TRAIL=1
TRAIL_ACTIVATE_PCT=5.0
TRAIL_PCT=2.0

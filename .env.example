# Binance Spot DEMO API credentials
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_api_secret_here

# Telegram alerts (optional — leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Order size in USDT (quote spent on each spot market buy)
ORDER_USDT=100

# Strategy: grid (default experiment) | fbb
STRATEGY=grid
GRID_STEP_PCT=1.0
GRID_STOP_LEVELS=3
MAX_POSITIONS=5

# Max concurrent REST fetches during warmup
MAX_CONCURRENCY=20

# --- FBB mode only (STRATEGY=fbb) ---
# 1m entry: FBB + prev quote 10K + candle 2% (no vol spike)
USE_VOL_SPIKE=0
VOL_SPIKE_LOOKBACK=5
VOL_SPIKE_MULT=2.0
MIN_CANDLE_BASE_VOL=0
MIN_CANDLE_QUOTE_VOL=10000
VOL_LOOKBACK=20
VOL_MULT=3.0
MIN_CANDLE_PCT=1.5

# FBB band refresh interval (seconds)
FBB_REFRESH_SEC=90

# Exit: hard -0.75% | 30%@+0.5 | 30%@+2 | BE +0.3% | trail +5% / -2%
PARTIAL_LADDER=0.5:0.30,2:0.30
HARD_STOP_PCT=0.75
USE_ENTRY_CANDLE_STOP=0
USE_BREAKEVEN=1
BREAKEVEN_PCT=0.3
USE_EMA_EXIT=0
EMA_PROGRESSIVE=0
EMA_EXIT_TF=5m
EMA_PROG_MODE=1m2m
USE_TRAIL=1
TRAIL_ACTIVATE_PCT=5.0
TRAIL_PCT=2.0

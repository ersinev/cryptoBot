# Binance Spot DEMO API credentials
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_api_secret_here

# Telegram alerts (optional — leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Order size in USDT (quote spent on each spot market buy)
ORDER_USDT=100

# Max concurrent REST fetches during warmup
MAX_CONCURRENCY=20

# 1m entry filters (prev closed 1m quote vol only — no rel)
MIN_CANDLE_QUOTE_VOL=10000
VOL_LOOKBACK=20
VOL_MULT=3.0
MIN_CANDLE_PCT=2.5

# FBB band refresh interval (seconds)
FBB_REFRESH_SEC=90

# Exit ladder: 40%@+3%, 30%@+5%, then +10% arms -3% trail on rest (~30%)
# Until trail arms: EMA9 + entry candle low
# EMA_PROGRESSIVE=1 + EMA_PROG_MODE=1m3m → <3% EMA1m, >=3% EMA3m (no 5m)
PARTIAL_LADDER=3:0.40,5:0.30
USE_TRAIL=1
EMA_EXIT_TF=5m
EMA_PROGRESSIVE=1
EMA_PROG_MODE=1m3m
TRAIL_ACTIVATE_PCT=10.0
TRAIL_PCT=3.0

# Binance USD-M Futures Testnet credentials
# https://testnet.binancefuture.com/
BINANCE_API_KEY=your_testnet_api_key
BINANCE_API_SECRET=your_testnet_api_secret

# true = Futures Testnet, false = live futures (use with extreme caution)
USE_TESTNET=true

# Quote volume filter (USDT)
MIN_QUOTE_VOLUME_USDT=5000000

# Order size in USDT notional per entry
ORDER_SIZE_USDT=50

# Max concurrent long positions (1 recommended for this strategy)
MAX_POSITIONS=1

# Leverage for new positions
LEVERAGE=5
